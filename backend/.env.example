# ─── Runtime ─────────────────────────────────────────────────────────────────
# "development" keeps convenient local defaults.
# "production" enforces a strong JWT secret and explicit CORS (used on the VM).
environment=development

# ─── Database ───────────────────────────────────────────────────────────────
# SQLite is the local default — no external DB server needed.
# On the VM this becomes a PostgreSQL URL, e.g.:
#   database_url=postgresql+psycopg2://alink:alink@127.0.0.1:5432/alink
database_url=sqlite:///./alink.db

# ─── JWT Auth ───────────────────────────────────────────────────────────────
# Generate a strong secret for production:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
jwt_secret=dev-only-secret-change-me
jwt_algorithm=HS256
jwt_expires_minutes=10080

# ─── CORS ───────────────────────────────────────────────────────────────────
cors_origins=http://localhost:5173,http://127.0.0.1:5173

# ─── Messaging (RabbitMQ) ────────────────────────────────────────────────────
# Leave unset locally to use the in-process fallback (no broker required).
# On the VM:
#   rabbitmq_url=amqp://alink:alink@127.0.0.1:5672/
# rabbitmq_url=
events_exchange=alink.events

# ─── AI assistant (optional) ─────────────────────────────────────────────────
# Without a key, the chat AI uses the local ML intent classifier.
# anthropic_api_key=
anthropic_model=claude-haiku-4-5

# ─── File Uploads ───────────────────────────────────────────────────────────
# upload_dir=uploads
# id_card_upload_limit_mb=5
# resume_upload_limit_mb=10
