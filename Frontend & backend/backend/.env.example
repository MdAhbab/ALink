# ─── Database ───────────────────────────────────────────────────────────────
# SQLite is the default.  No external DB server needed.
database_url=sqlite:///./alink.db

# ─── JWT Auth ───────────────────────────────────────────────────────────────
jwt_secret=dev-only-secret-change-me
jwt_algorithm=HS256
jwt_expires_minutes=10080

# ─── CORS ───────────────────────────────────────────────────────────────────
cors_origins=http://localhost:5173,http://127.0.0.1:5173

# ─── File Uploads ───────────────────────────────────────────────────────────
# upload_dir=uploads
# id_card_upload_limit_mb=5
# resume_upload_limit_mb=10
